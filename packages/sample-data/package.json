{
  "name": "@shopify-next-cms/sample-data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "sample-data": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
