{
  "name": "shopify-next-cms",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:docs": "turbo run dev --filter=docs",
    "dev:web": "turbo run dev --filter=shopify-next-cms",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "sample-data": "pnpm --filter @shopify-next-cms/sample-data sample-data"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.18.3"
}
